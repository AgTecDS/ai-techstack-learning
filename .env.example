# ══════════════════════════════════════════════════════════════════════════════
# .env.example — copy this to .env and fill in real values
#
#   cp .env.example .env
#
# .env is listed in .gitignore and will NOT be committed.
# Never commit real secrets to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ailearning
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ailearning

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Optional: API key for Qdrant Cloud
# QDRANT_API_KEY=your_qdrant_cloud_api_key

# ── MinIO / S3 object storage ──────────────────────────────────────────────────
# For local MinIO:
S3_ENDPOINT=http://localhost:9000
S3_KEY=minio
S3_SECRET=minio123

# For AWS S3 (comment out S3_ENDPOINT and set these instead):
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_DEFAULT_REGION=us-east-1

# ── Model paths ────────────────────────────────────────────────────────────────
MODEL_CHECKPOINT=./phase1_python_ml/mnist_cnn.pth
ONNX_MODEL_PATH=./phase3_edge_ai/mnist_cnn.onnx
ONNX_INT8_MODEL_PATH=./phase3_edge_ai/mnist_cnn_int8.onnx

# ── FastAPI ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Set to "production" to disable debug endpoints
ENVIRONMENT=development

# ── Streamlit ──────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
